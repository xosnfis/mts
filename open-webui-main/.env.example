# ============================================================
# OpenWebUI + MWS GPT — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── MWS GPT primary backend ───────────────────────────────────────────────────
# MWS_GPT_API_KEY=sk-your-key-here
# OPENAI_API_BASE_URLS=https://api.gpt.mws.ru/v1
# OPENAI_API_KEYS=sk-your-key-here
# DEFAULT_MODELS=mws-gpt-alpha
# ENABLE_OLLAMA_API=false

# ── Legacy single-URL form (still supported) ──────────────────────────────────
OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# ── Ollama (local, optional) ──────────────────────────────────────────────────
OLLAMA_BASE_URL='http://localhost:11434'

# ── Фича 2: Голосовой чат / Speech-to-Text ───────────────────────────────────
# AUDIO_STT_ENGINE=openai          # 'openai' = server-side via /audio/transcriptions
#                                  # ''       = local faster-whisper
#                                  # 'web'    = browser SpeechRecognition (live only)
# AUDIO_STT_OPENAI_API_BASE_URL=https://api.gpt.mws.ru/v1
# AUDIO_STT_OPENAI_API_KEY=sk-your-key-here
# AUDIO_STT_MODEL=whisper-1

# ── Фича 2: Text-to-Speech (озвучка ответов) ─────────────────────────────────
# AUDIO_TTS_ENGINE=openai
# AUDIO_TTS_OPENAI_API_BASE_URL=https://api.gpt.mws.ru/v1
# AUDIO_TTS_OPENAI_API_KEY=sk-your-key-here
# AUDIO_TTS_MODEL=tts-1
# AUDIO_TTS_VOICE=alloy

# ── Фича 3: Генерация изображений в чате ─────────────────────────────────────
# ENABLE_IMAGE_GENERATION=true
# IMAGE_GENERATION_ENGINE=openai
# IMAGES_OPENAI_API_BASE_URL=https://api.gpt.mws.ru/v1
# IMAGES_OPENAI_API_KEY=sk-your-key-here
# IMAGE_GENERATION_MODEL=dall-e-2
# IMAGE_SIZE=1024x1024
# ENABLE_IMAGE_PROMPT_GENERATION=true

# ── Фича 6: Файлы / RAG — Embeddings (bge-m3 via MWS GPT) ───────────────────
# RAG_EMBEDDING_ENGINE=openai
# RAG_EMBEDDING_MODEL=bge-m3
# RAG_OPENAI_API_BASE_URL=https://api.gpt.mws.ru/v1
# RAG_OPENAI_API_KEY=sk-your-key-here
# RAG_TOP_K=5
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=200

# ── Фича 7: Поиск в интернете (DuckDuckGo — free, no API key) ────────────────
# ENABLE_WEB_SEARCH=true
# WEB_SEARCH_ENGINE=duckduckgo
# WEB_SEARCH_RESULT_COUNT=8
# BYPASS_WEB_SEARCH_EMBEDDING_AND_RETRIEVAL=false

# ── Фича 8: Веб-парсинг по ссылке ────────────────────────────────────────────
# ENABLE_RAG_LOCAL_WEB_FETCH=true
# WEB_LOADER_TIMEOUT=30

# ── Фича 9: Долгосрочная память ───────────────────────────────────────────────
# ENABLE_MEMORIES=true

# ── Общие ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGIN='*'
FORWARDED_ALLOW_IPS='*'

SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
